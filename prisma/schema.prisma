// Asentamiento v0 — esquema de datos.
// Principio rector: el servidor es la única fuente de verdad.
// Toda la lógica de balance vive en lib/gameConfig.ts, NO aquí.
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Identidad del jugador. Es a la vez el User de Auth.js (Google + credenciales)
// y el dueño de un asentamiento. Antes existía un modelo Player separado; se
// fusionó aquí para tener una sola identidad.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  // Nombre de usuario para login dual (email O username). Único e inmutable.
  // Nullable porque los usuarios de Google se dan de alta sin él; el registro por
  // credenciales siempre lo exige. Se almacena en minúsculas para unicidad.
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // solo para login con email/contraseña (null si solo usa Google)
  createdAt     DateTime  @default(now())

  // --- Referidos (Bloque 3) ---
  // Código único e inmutable que comparte el jugador en su enlace de invitación.
  referralCode     String    @unique @default(cuid())
  // Quién invitó a este usuario (null = registro orgánico, sin referidor).
  referredById     String?
  referredBy       User?     @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]    @relation("Referrals")
  // Cuándo se entregó la recompensa al referidor (al llegar ESTE usuario a Ayto. N2).
  // null = aún no entregada. Garantiza que la recompensa se paga una sola vez.
  referralRewardAt DateTime?

  accounts     Account[]
  sessions     Session[]
  settlement   Settlement?
  achievements UserAchievement[]
}

// Hazañas COMPLETADAS por un usuario. Las DEFINICIONES de hazañas (título,
// condición, recompensa) NO viven en la BD: viven en lib/achievements.ts, igual
// que el resto del balance en lib/gameConfig.ts. Aquí solo se persiste el hecho
// de haber completado una hazaña (por su id de definición) y cuándo.
model UserAchievement {
  id            String    @id @default(cuid())
  userId        String
  achievementId String // id de la definición en lib/achievements.ts (p. ej. "wood_1")
  completedAt   DateTime  @default(now())
  // Cuándo reclamó el jugador la recompensa (canje manual). La recompensa SOLO se
  // aplica al reclamar, nunca al detectar la completitud.
  //   completedAt != null + claimedAt == null → completada, pendiente de canje
  //   claimedAt != null                       → reclamada, recompensa ya aplicada
  claimedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// Tablas estándar de Auth.js (adaptador de Prisma).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Settlement {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String    @unique
  name          String    @default("Asentamiento sin nombre") // nombre del asentamiento, definido por el jugador
  nameChangedAt DateTime? // último renombre; null = nunca renombrado (cooldown de 24h)
  townHallLevel Int       @default(1) // nivel del Ayuntamiento: techo global

  // Región (mundo) del asentamiento. Se elige en el onboarding y es PERMANENTE.
  // Nullable mientras el jugador no ha completado la selección de región.
  region Region?

  // Posición en el tablero 2D abstracto de su región (0–100). Se asigna de forma
  // procedural al fijar la región. Null hasta entonces.
  posX Float?
  posY Float?

  // Recursos (cantidades actuales)
  food    Float @default(0)
  wood    Float @default(0)
  stone   Float @default(0)
  welfare Float @default(100) // bienestar, arranca al 100%

  // Producción BRUTA acumulada (Bloque 3): suma de todo lo producido a lo largo de
  // la vida del asentamiento, sin restar consumo ni topes de almacén. Solo crece.
  // La usan las hazañas de tipo `total_*_produced`. El motor diferido lo incrementa
  // en cada recálculo con la producción bruta del tramo.
  totalFoodProduced  Float @default(0)
  totalWoodProduced  Float @default(0)
  totalStoneProduced Float @default(0)

  // Población
  population Int @default(3) // colonos totales (asignados + libres)

  // ¿Ya llegó el primer colono nuevo por crecimiento? (Cambio A, bloque 4) Mientras
  // es false, el primer colono usa el umbral acelerado (firstColonistHours); el resto,
  // la cadencia normal de 24h. El motor diferido lo pone a true al recibir el primero.
  firstColonistReceived Boolean @default(false)

  // Motor de cálculo diferido
  lastTick DateTime @default(now())

  // Acumuladores de progreso entre recálculos (no están en el diseño v0 original,
  // pero el motor diferido los necesita para que el progreso no se reinicie en cada
  // interacción: sin esto, abrir la app a menudo impediría crecer o caer en hambruna).
  growthProgress Float @default(0) // horas elegibles acumuladas hacia el próximo colono
  famineProgress Float @default(0) // horas de bienestar bajo umbral acumuladas hacia la próxima pérdida

  // Progreso del tutorial (Cambio C): mapa { stepId: true } de los coachmarks ya
  // vistos. En BD (no localStorage) para que sobreviva a borrar el navegador.
  // Las claves válidas viven en lib/tutorial.ts, no aquí.
  tutorialProgress Json @default("{}")

  // Eventos aleatorios (Bloque 4): timestamp del último evento GENERADO. El motor de
  // generación diferida (lib/events.ts) lo compara con el instante actual para decidir
  // si toca generar uno nuevo, sin necesidad de cron.
  lastEventAt DateTime?

  // --- Tributo recibido como SEÑOR (Bloque 6, §1.4) ---
  // Total acumulado de recursos que los vasallos han cedido a este asentamiento a lo
  // largo del tiempo (línea separada en el inventario del señor). Solo crece; el motor
  // diferido del vasallo lo incrementa al ceder su parte. El recurso EFECTIVO ya se
  // suma a food/wood/stone (acotado por almacén); estos contadores son informativos.
  tributeReceivedFood  Float @default(0)
  tributeReceivedWood  Float @default(0)
  tributeReceivedStone Float @default(0)

  buildings   Building[]
  events      Event[]
  worldEvents WorldEvent[]

  // --- Conquista y vasallaje (Bloque 6, §1) ---
  // Vasallaje en el que ESTE asentamiento es el SEÑOR (puede tener muchos vasallos).
  vassals  Vassalage[] @relation("LordVassals")
  // Vasallaje en el que ESTE asentamiento es el VASALLO (como mucho uno; de ahí el
  // @unique en Vassalage.vassalId). null = asentamiento libre.
  overlord Vassalage?  @relation("VassalLord")
  // Guerras declaradas por/contra este asentamiento (historial e idempotencia de cooldown).
  warsAttacked WarDeclaration[] @relation("Attacker")
  warsDefended WarDeclaration[] @relation("Defender")

  createdAt DateTime @default(now())
}

model Building {
  id           String       @id @default(cuid())
  settlement   Settlement   @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String
  type         BuildingType
  level        Int          @default(1)
  workers      Int          @default(0) // colonos asignados a ESTE edificio

  // Construcción/mejora en curso. Si NO es null, el edificio está levantándose o
  // mejorando y pasará a `level + 1` en este instante; el motor diferido lo
  // completa al cruzar el timestamp (igual que el crecimiento de población).
  // Un edificio recién encargado arranca en level 0 (no funcional) y sube a 1 al
  // terminar; una mejora mantiene su nivel actual (sigue produciendo) hasta acabar.
  constructionEndsAt DateTime?

  createdAt DateTime @default(now())

  @@index([settlementId])
}

enum BuildingType {
  TOWN_HALL // Ayuntamiento: limita nº de edificios y nivel máximo de cada uno
  FARM // Granja: produce comida (requiere colonos)
  SAWMILL // Serrería: produce madera (requiere colonos)
  QUARRY // Cantera: produce piedra (requiere colonos; se desbloquea más tarde)
  HOUSE // Casa: aumenta capacidad de población
  WAREHOUSE // Almacén: aumenta topes de almacenamiento
  PLAZA // Plaza: genera bienestar (requiere colonos)
  BARRACKS // Cuartel (Bloque 6): aloja soldados (colonos asignados) → fuerza militar
  WALL // Muralla (Bloque 6): defensa por nivel → fuerza militar (no requiere colonos)
}

model Event {
  id           String     @id @default(cuid())
  settlement   Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String
  type         EventType
  payload      Json // datos del efecto, flexible
  occurredAt   DateTime   @default(now())
  seen         Boolean    @default(false) // si el jugador ya lo vio al reconectar

  @@index([settlementId])
}

enum EventType {
  COLONIST_ARRIVED
  PLAGUE
  FAMINE // hambruna: pérdida de población por bienestar bajo
  // Guerra (Bloque 6): WAR_ATTACK = resultado de un ataque que YO lancé; WAR_DEFENSE =
  // me atacaron a MÍ. El desenlace (victoria/derrota, vasallaje) va en el payload.
  WAR_ATTACK
  WAR_DEFENSE
  // Futuro: ALLIANCE_REQUEST, etc.
}

// Eventos aleatorios interactivos (Bloque 4 §B): mercaderes que ofrecen tratos,
// inclemencias que aplican un efecto, peregrini que traen colonos. A diferencia de
// `Event` (log interno del motor: plaga/hambruna/colono, con flag `seen`), estos son
// eventos con NARRATIVA y RESPUESTA del jugador (aceptar/rechazar) o efecto directo.
// La narrativa, el pool de personajes y la lógica viven en lib/events.ts.
model WorldEvent {
  id           String          @id @default(cuid())
  settlement   Settlement      @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String
  type         WorldEventType
  status       WorldEventStatus @default(PENDING)
  // Clave del personaje del pool en lib/events.ts (ej. "mercator_01"). Null en las
  // inclemencias (texto objetivo, sin personaje).
  characterKey String?
  // Datos de la mecánica: trade → { give:{resource,amount}, receive:{resource,amount} };
  // inclemencia/colono → { effect:{...} }. La forma exacta la define lib/events.ts.
  payload      Json
  createdAt    DateTime         @default(now())
  expiresAt    DateTime // createdAt + EVENTS.responseHours; al cruzarlo pasa a EXPIRED
  resolvedAt   DateTime?

  @@index([settlementId, status])
}

enum WorldEventType {
  TRADE_FAVORABLE
  TRADE_NEUTRAL
  TRADE_UNFAVORABLE
  INCLEMENCY
  COLONIST_ARRIVAL
  // Reservados para fases futuras: MILITARY, SPECIAL
}

enum WorldEventStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// Las 10 regiones de la Hispania romana. La región define el "mundo" online del
// jugador: con quién comparte tablero. Los textos (nombre en juego, lore, color)
// viven en lib/regionConfig.ts, NO aquí.
enum Region {
  GALLAECIA
  CANTABRIA_ET_ASTURES
  TARRACONENSIS
  CAESARAUGUSTA
  CELTIBERIA
  LUSITANIA
  CARTHAGINENSIS
  BAETICA
  INSULAE_BALEARES
  INSULAE_FORTUNATAE
}

// Asentamientos neutrales (NPC) de cada región. En v1 solo son visibles en el
// mapa; en fases futuras serán atacables/conquistables. Se generan de forma
// procedural y determinista (seed por región) la primera vez que alguien entra
// en esa región. Las posiciones son sobre el tablero 2D abstracto (0–100).
model NeutralSettlement {
  id        String   @id @default(cuid())
  name      String
  region    Region
  level     Int      @default(1)
  posX      Float // posición en mapa 2D abstracto (0–100)
  posY      Float
  createdAt DateTime @default(now())

  @@index([region])
}

// Relación de vasallaje (Bloque 6, §1.1). Jerarquía PLANA: un vasallo tiene
// exactamente un señor (de ahí @unique en vassalId) y un vasallo NO puede tener
// vasallos propios. Al conquistar a un señor, sus vasallos se liberan (lib/warfare.ts).
model Vassalage {
  id         String   @id @default(cuid())
  lordId     String
  vassalId   String   @unique // un vasallo tiene como mucho un señor
  // % de producción que el vasallo cede al señor. Fijo por diseño en v1
  // (gameConfig.MILITARY.vassalTributePct); se copia aquí al crear el vasallaje.
  tributePct Int      @default(15)
  startedAt  DateTime @default(now())

  lord   Settlement @relation("LordVassals", fields: [lordId], references: [id], onDelete: Cascade)
  vassal Settlement @relation("VassalLord", fields: [vassalId], references: [id], onDelete: Cascade)

  @@index([lordId])
}

// Declaración de guerra (Bloque 6, §1.2). La resolución es INMEDIATA por stats: al
// crearse ya se rellenan winnerId/resolvedAt y las fuerzas de ambos bandos (registro
// histórico e idempotencia del cooldown de 48h entre el mismo agresor y defensor).
model WarDeclaration {
  id            String    @id @default(cuid())
  attackerId    String
  defenderId    String
  declaredAt    DateTime  @default(now())
  resolvedAt    DateTime?
  winnerId      String?
  attackerForce Int
  defenderForce Int
  // ¿Era una rebelión de un vasallo contra su señor? (§1.5) Cambia las consecuencias:
  // si el vasallo gana, queda libre (en vez de tomar al defensor como vasallo).
  isRebellion   Boolean   @default(false)

  attacker Settlement @relation("Attacker", fields: [attackerId], references: [id], onDelete: Cascade)
  defender Settlement @relation("Defender", fields: [defenderId], references: [id], onDelete: Cascade)

  @@index([attackerId, defenderId, declaredAt])
}
