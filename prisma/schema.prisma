// Asentamiento v0 — esquema de datos.
// Principio rector: el servidor es la única fuente de verdad.
// Toda la lógica de balance vive en lib/gameConfig.ts, NO aquí.
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Identidad del jugador. Es a la vez el User de Auth.js (Google + credenciales)
// y el dueño de un asentamiento. Antes existía un modelo Player separado; se
// fusionó aquí para tener una sola identidad.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  // Nombre de usuario para login dual (email O username). Único e inmutable.
  // Nullable porque los usuarios de Google se dan de alta sin él; el registro por
  // credenciales siempre lo exige. Se almacena en minúsculas para unicidad.
  username      String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // solo para login con email/contraseña (null si solo usa Google)
  createdAt     DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  settlement Settlement?
}

// Tablas estándar de Auth.js (adaptador de Prisma).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Settlement {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String    @unique
  name          String    @default("Asentamiento sin nombre") // nombre del asentamiento, definido por el jugador
  nameChangedAt DateTime? // último renombre; null = nunca renombrado (cooldown de 24h)
  townHallLevel Int       @default(1) // nivel del Ayuntamiento: techo global

  // Región (mundo) del asentamiento. Se elige en el onboarding y es PERMANENTE.
  // Nullable mientras el jugador no ha completado la selección de región.
  region Region?

  // Posición en el tablero 2D abstracto de su región (0–100). Se asigna de forma
  // procedural al fijar la región. Null hasta entonces.
  posX Float?
  posY Float?

  // Recursos (cantidades actuales)
  food    Float @default(0)
  wood    Float @default(0)
  stone   Float @default(0)
  welfare Float @default(100) // bienestar, arranca al 100%

  // Población
  population Int @default(3) // colonos totales (asignados + libres)

  // Motor de cálculo diferido
  lastTick DateTime @default(now())

  // Acumuladores de progreso entre recálculos (no están en el diseño v0 original,
  // pero el motor diferido los necesita para que el progreso no se reinicie en cada
  // interacción: sin esto, abrir la app a menudo impediría crecer o caer en hambruna).
  growthProgress Float @default(0) // horas elegibles acumuladas hacia el próximo colono
  famineProgress Float @default(0) // horas de bienestar bajo umbral acumuladas hacia la próxima pérdida

  buildings Building[]
  events    Event[]

  createdAt DateTime @default(now())
}

model Building {
  id           String       @id @default(cuid())
  settlement   Settlement   @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String
  type         BuildingType
  level        Int          @default(1)
  workers      Int          @default(0) // colonos asignados a ESTE edificio

  // Construcción/mejora en curso. Si NO es null, el edificio está levantándose o
  // mejorando y pasará a `level + 1` en este instante; el motor diferido lo
  // completa al cruzar el timestamp (igual que el crecimiento de población).
  // Un edificio recién encargado arranca en level 0 (no funcional) y sube a 1 al
  // terminar; una mejora mantiene su nivel actual (sigue produciendo) hasta acabar.
  constructionEndsAt DateTime?

  createdAt DateTime @default(now())

  @@index([settlementId])
}

enum BuildingType {
  TOWN_HALL // Ayuntamiento: limita nº de edificios y nivel máximo de cada uno
  FARM // Granja: produce comida (requiere colonos)
  SAWMILL // Serrería: produce madera (requiere colonos)
  QUARRY // Cantera: produce piedra (requiere colonos; se desbloquea más tarde)
  HOUSE // Casa: aumenta capacidad de población
  WAREHOUSE // Almacén: aumenta topes de almacenamiento
  PLAZA // Plaza: genera bienestar (requiere colonos)
}

model Event {
  id           String     @id @default(cuid())
  settlement   Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String
  type         EventType
  payload      Json // datos del efecto, flexible
  occurredAt   DateTime   @default(now())
  seen         Boolean    @default(false) // si el jugador ya lo vio al reconectar

  @@index([settlementId])
}

enum EventType {
  COLONIST_ARRIVED
  PLAGUE
  FAMINE // hambruna: pérdida de población por bienestar bajo
  // Futuro: ATTACKED, ALLIANCE_REQUEST, etc. (no implementar en v0)
}

// Las 10 regiones de la Hispania romana. La región define el "mundo" online del
// jugador: con quién comparte tablero. Los textos (nombre en juego, lore, color)
// viven en lib/regionConfig.ts, NO aquí.
enum Region {
  GALLAECIA
  CANTABRIA_ET_ASTURES
  TARRACONENSIS
  CAESARAUGUSTA
  CELTIBERIA
  LUSITANIA
  CARTHAGINENSIS
  BAETICA
  INSULAE_BALEARES
  INSULAE_FORTUNATAE
}

// Asentamientos neutrales (NPC) de cada región. En v1 solo son visibles en el
// mapa; en fases futuras serán atacables/conquistables. Se generan de forma
// procedural y determinista (seed por región) la primera vez que alguien entra
// en esa región. Las posiciones son sobre el tablero 2D abstracto (0–100).
model NeutralSettlement {
  id        String   @id @default(cuid())
  name      String
  region    Region
  level     Int      @default(1)
  posX      Float // posición en mapa 2D abstracto (0–100)
  posY      Float
  createdAt DateTime @default(now())

  @@index([region])
}
